// Inspired by Catnap
{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "source": "~/dotfiles/.config/fastfetch/window.txt",
        "padding": {
            "top": 2,
            "left": 2
        },
        "color": {
            "1": "green",
            "2": "yellow",
            "3": "red",
            "4": "blue",
            "5": "magenta",
            "6": "white"
        },
    },
    "display": {
        "separator": " "
    },
    "modules": [
        {
            "key": "╭───────────╮",
            "type": "custom"
        },
        {
            "key": "│ {#31} user    {#keys}│",
            "type": "title",
            "format": "{user-name}@{host-name}"
        },
        {
            "key": "│ {#32}󰅐 uptime  {#keys}│",
            "type": "uptime"
        },
        {
            "key": "│ {#33}{icon} distro  {#keys}│",
            "type": "os"
        },
        {
            "key": "│ {#34} kernel  {#keys}│",
            "type": "kernel"
        },
        {
            "key": "│ {#35} term    {#keys}│",
            "type": "terminal"
        },
        {
            "key": "│ {#36} shell   {#keys}│",
            "type": "shell"
        },
        {
            "key": "│ {#31}󰝚 media   {#keys}│",
            "type": "media"
        },
        {
            "key": "├───────────┤",
            "type": "custom"
        },
        {
            "key": "│ {#32}󰌢 PC      {#keys}│",
            "type": "host"
        },
        {
            "key": "│ {#33}󰍛 cpu     {#keys}│",
            "type": "cpu",
            "showPeCoreCount": true
        },
        {
            "key": "│ {#34}󰢮 gpu     {#keys}│",
            "type": "gpu"
        },
        {
            "key": "│ {#35}󰘚 memory  {#keys}│",
            "type": "memory"
        },
        {
            "key": "│ {#36}󰉉 disk    {#keys}│",
            "type": "disk"
        },
        {
            "key": "│ {#31}󰇄 display {#keys}│",
            "type": "display"
        },
        {
            "key": "├───────────┤",
            "type": "custom"
        },
        {
            "key": "│ {#39} colors  {#keys}│",
            "type": "colors",
            "symbol": "circle"
        },
        {
            "key": "╰───────────╯",
            "type": "custom"
        }
    ]
}
